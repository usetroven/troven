# ============================================================
# Troven.Stack — Environment Variables
# Copy this file to .env.local and fill in all values.
# ============================================================

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.pgymdckipftoxricqpep.supabase.co:5432/postgres"

# --- Clerk Authentication ---
# https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Troven.Stack"

# --- Email (Resend) ---
# https://resend.com/api-keys
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@yourdomain.com"

# --- Uploadthing (file uploads, optional) ---
UPLOADTHING_SECRET="sk_live_..."
UPLOADTHING_APP_ID="..."
